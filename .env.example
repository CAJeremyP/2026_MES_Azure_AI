# Azure Subscription
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=rg-ai-demo
AZURE_LOCATION=eastus

# Unique prefix for resource names (3-8 lowercase letters, no hyphens)
RESOURCE_PREFIX=aidemo

# --- Populated automatically by deploy.sh / deploy.bat ---
# (You can also fill these in manually after deploying via the portal)

# Azure Blob Storage
STORAGE_ACCOUNT_NAME=
STORAGE_CONNECTION_STRING=
STORAGE_CONTAINER_NAME=demo-images

# Azure Custom Vision
CUSTOM_VISION_TRAINING_ENDPOINT=
CUSTOM_VISION_TRAINING_KEY=
CUSTOM_VISION_PREDICTION_ENDPOINT=
CUSTOM_VISION_PREDICTION_KEY=
CUSTOM_VISION_PROJECT_ID=
CUSTOM_VISION_PUBLISH_NAME=demov1

# Azure Document Intelligence (Form Recognizer)
DOCUMENT_INTELLIGENCE_ENDPOINT=
DOCUMENT_INTELLIGENCE_KEY=

# Azure SQL (serverless)
SQL_SERVER_NAME=
SQL_DATABASE_NAME=aidemodb
SQL_ADMIN_USER=demoadmin
SQL_ADMIN_PASSWORD=Demo@Pass123!   # Change before any real use
SQL_CONNECTION_STRING=
